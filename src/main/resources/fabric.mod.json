{
	"schemaVersion": 1,
	"id": "world-panorama",
	"version": "${version}",
	"name": "World Panorama",
	"description": "Load a real world instead of a static image for the panorama",
	"authors": [
		"kr1v",
        "Tektonikal"
	],
	"contact": {
		"homepage": "https://kr1v.net/",
		"sources": "https://github.com/kr1viah/WorldPanorama/"
	},
	"license": "MIT",
	"icon": "assets/world-panorama/icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
			"net.kr1v.worldpanorama.WorldPanorama"
		],
		"client": [
			"net.kr1v.worldpanorama.client.WorldPanoramaClient"
		]
	},
	"mixins": [
		"world-panorama.mixins.json",
		{
			"config": "world-panorama.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.1",
		"java": ">=25",
		"fabric-api": "*",
